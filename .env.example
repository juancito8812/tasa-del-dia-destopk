# ─── Configuración de Tasa del Día ──────────────────────────────
# Copia este archivo a .env y ajusta los valores según sea necesario.
#
# Para usar variables de entorno, ejecuta:
#   set COTIZAVE_BASE_URL=https://api.cotizave.com  (Windows)
#   export COTIZAVE_BASE_URL=https://api.cotizave.com  (Linux/Mac)

# URL base de la API de Cotizave
# Por defecto: https://api.cotizave.com
# COTIZAVE_BASE_URL=https://api.cotizave.com

# Nivel de logging: DEBUG, INFO, WARNING, ERROR
# LOG_LEVEL=INFO